{
  "manifest_version": 3,
  "name": "Human Mouse Drift",
  "version": "1.0.0",
  "description": "Simulates subtle human-like mouse movement inside webpages for testing.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Human Mouse Drift"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
